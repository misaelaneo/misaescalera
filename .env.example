# EmailJS configuration (public values — safe to expose in frontend by design)
# Create an account at https://www.emailjs.com, add an email service + template,
# then copy the IDs here. Copy this file to .env for local dev, and add these
# as repository variables for the GitHub Actions build.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
